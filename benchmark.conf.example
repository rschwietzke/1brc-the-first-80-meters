# Unified Benchmark Configuration
# This file defines the properties and matrix combinations for benchmarking.

[JDKS]
# Format: LABEL = PATH_OR_SDKMAN_ID
JDK_21_OPEN = sdkman:21.0.2-open
LOCAL_JDK = /usr/lib/jvm/java-25-openjdk

[GC_OPTS]
# Format: LABEL = JVM GC FLAGS
ZGC = -XX:+UseZGC
G1 = -XX:+UseG1GC

[VM_OPTS]
# Format: LABEL = JVM MEMORY AND OTHER FLAGS
MEM_2G = -Xms2g -Xmx2g
DEFAULT = 

[PROG_OPTS]
# Format: LABEL = APP ARGUMENTS
DEFAULT = 
DEBUG = --debug

[TASKSETS]
# Format: LABEL = TASKSET PARAMS
CORES_8 = -c 0-7
ALL = 

[DATASETS]
# Format: LABEL = PATH
DATASET_10M = 10000000.txt
DATASET_1B = 1000M.txt

[RUN:NIGHTLY_ZGC]
JDK_FILTER = JDK_21_OPEN
GC_FILTER = ZGC
VM_FILTER = MEM_2G
TASKSET_FILTER = CORES_8
PROG_FILTER = DEFAULT
DATA_FILTER = 10M
CLASS_FILTER = *

[RUN:DEBUG_PKG]
JDK_FILTER = JDK_21_OPEN
GC_FILTER = G1
VM_FILTER = DEFAULT
TASKSET_FILTER = ALL
PROG_FILTER = DEFAULT
DATA_FILTER = 10M
CLASS_FILTER = org.rschwietzke.st.*

[RUN:ALL_MATRIX]
# By omitting filters, they default to '*' and evaluate all combinable parameters.

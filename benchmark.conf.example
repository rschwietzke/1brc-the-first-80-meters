# Unified Benchmark Configuration
# This file defines the properties and matrix combinations for benchmarking.

[JDKS]
# Format: LABEL = PATH_OR_SDKMAN_ID
JDK_21_OPEN = sdkman:21.0.2-open
LOCAL_JDK = /usr/lib/jvm/java-25-openjdk

[GC_OPTS]
# Format: LABEL = JVM GC FLAGS
ZGC = -XX:+UseZGC
G1 = -XX:+UseG1GC

[VM_OPTS]
# Format: LABEL = JVM MEMORY AND OTHER FLAGS
MEM_2G = -Xms2g -Xmx2g
DEFAULT = 

[PROG_OPTS]
# Format: LABEL = APP ARGUMENTS
DEFAULT = 
DEBUG = --debug

[TASKSETS]
# Format: LABEL = TASKSET PARAMS
CORES_8 = -c 0-7
ALL = 

[DATASETS]
# Format: LABEL = PATH
DATASET_10M = 10000000.txt
DATASET_1B = 1000M.txt

[RUNS]
# Format: RUN_NAME = JDK_LABEL ; GC_LABEL ; VM_LABEL ; TASKSET_LABEL ; PROG_LABEL ; DATASET_LABEL ; CLASS_FILTER
# Use * as a wildcard to run all available valid elements for that dimension.
# CLASS_FILTER can be a specific class (e.g., BRC13_HardcodedSetST), a package (e.g., org.rschwietzke.st.*), or * for all valid classes.
NIGHTLY_ZGC = JDK_21_OPEN ; ZGC ; MEM_2G ; CORES_8 ; DEFAULT ; DATASET_10M ; *
DEBUG_ST    = JDK_21_OPEN ; G1 ; DEFAULT ; ALL ; DEFAULT ; DATASET_10M ; org.rschwietzke.st.*
ALL_MATRIX  = * ; * ; * ; * ; * ; * ; *
